{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "compile": {
      "inputs": ["src/**/*", "contracts/**/*"],
      "dependsOn": ["^compile"]
    },
    "lint": {
      "inputs": ["src/**/*", "scripts/**/*", "test/**/*", "tests/**/*"]
    },
    "check-types": {
      "inputs": ["src/**/*", "scripts/**/*", "test/**/*", "tests/**/*"],
      "dependsOn": ["^compile"]
    }
  }
}
