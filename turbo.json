{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "enabled": true
  },
  "tasks": {
    "compile": {
      "inputs": ["src/**", "contracts/**/*.sol"],
      "outputs": ["dist/**", "artifacts/**", "typechain-types/**", "cache"],
      "dependsOn": ["^compile"]
    },
    "lint": {
      "inputs": ["src/**", "scripts/**", "test/**", "tests/**"]
    },
    "check-types": {
      "inputs": ["src/**", "scripts/**", "test/**", "tests/**"],
      "dependsOn": ["compile"]
    }
  }
}
