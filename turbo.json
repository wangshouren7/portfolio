{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "compile": {
      "inputs": ["src/**/*", "contracts/**/*"],
      "dependsOn": ["^compile"],
      "outputs": [
        "dist/**/*",
        "cache/**/*",
        "artifacts/**/*",
        "typechain-types/**/*"
      ]
    },
    "lint": {
      "inputs": ["src/**/*", "scripts/**/*", "test/**/*", "tests/**/*"]
    },
    "check-types": {
      "inputs": ["src/**/*", "scripts/**/*", "test/**/*", "tests/**/*"],
      "dependsOn": ["^compile"]
    }
  }
}
